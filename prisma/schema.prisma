generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  Admin
  EventManager
  Volunteer
  Attendee
}

enum EventStatus {
  draft
  published
  cancelled
}

enum PromoType {
  flat
  percent
}

enum BookingStatus {
  pending
  confirmed
  cancelled
}

// NEW: tracks every Razorpay payment (all money lands in admin's account)
enum PaymentStatus {
  pending      // order created, user hasn't paid yet
  paid         // payment verified & booking confirmed
  failed       // payment failed or signature mismatch
  refunded     // admin issued a refund via Razorpay
  distributed  // admin has transferred share to organizer
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      Role     @default(Attendee)
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events             Event[]
  bookings           Booking[]
  organizerPayments  Payment[]  @relation("OrganizerPayments")
}

model Event {
  id                Int            @id @default(autoincrement())
  title             String
  description       String
  date              DateTime
  location          String?
  venue             String?
  venueType         String?
  category          String?
  sportType         String?
  trending          Boolean        @default(false)
  rating            Float          @default(0)
  status            EventStatus    @default(published)
  price             Int            @default(0)
  ownerId           String?
  participationType String         @default("solo")
  maxTeamSize       Int            @default(1)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  owner    User?     @relation(fields: [ownerId], references: [id])
  tickets  Ticket[]
  bookings Booking[]
  payments Payment[]
}

model Ticket {
  id        Int      @id @default(autoincrement())
  eventId   Int
  name      String
  price     Int
  capacity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event    Event    @relation(fields: [eventId], references: [id])
  bookings Booking[]
}

model PromoCode {
  id        Int       @id @default(autoincrement())
  code      String    @unique
  type      PromoType
  value     Int
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  bookings Booking[]
}

// NEW: one Payment record per Razorpay transaction
model Payment {
  id                  String        @id @default(cuid())
  razorpayOrderId     String        @unique          // from Razorpay order creation
  razorpayPaymentId   String?       @unique          // from Razorpay after user pays
  razorpaySignature   String?                        // HMAC signature from Razorpay
  amount              Int                            // in paise (₹1 = 100 paise)
  currency            String        @default("INR")
  status              PaymentStatus @default(pending)

  // links to the event so admin can see per-organizer revenue
  eventId             Int
  organizerId         String?                        // event's ownerId at time of payment

  // admin distribution tracking
  distributedAt       DateTime?
  distributedAmount   Int?                           // how much the admin sent to organizer (paise)
  distributionNote    String?                        // e.g. "Bank transfer ref #12345"

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  booking   Booking?  @relation("BookingPayment")
  event     Event     @relation(fields: [eventId], references: [id])
  organizer User?     @relation("OrganizerPayments", fields: [organizerId], references: [id])
}

model Booking {
  id            String        @id @default(cuid())
  ticketCode    String        @unique
  userId        String?
  eventId       Int
  ticketId      Int
  quantity      Int
  attendeeName  String
  attendeeEmail String
  attendeePhone String?
  delivery      String
  unitPrice     Int
  subtotal      Int
  discount      Int
  groupDiscount Int
  total         Int
  promoCodeId   Int?
  status        BookingStatus @default(confirmed)
  checkedInAt   DateTime?
  teamName      String?
  teamSize      Int           @default(1)
  teamMembers   Json?

  // NEW: link to the payment that funded this booking (null for free events)
  paymentId     String?       @unique

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user    User?      @relation(fields: [userId], references: [id])
  event   Event      @relation(fields: [eventId], references: [id])
  ticket  Ticket     @relation(fields: [ticketId], references: [id])
  promo   PromoCode? @relation(fields: [promoCodeId], references: [id])
  payment Payment?   @relation("BookingPayment", fields: [paymentId], references: [id])
}
